<html lang="en" class="light" style="--sidebar-w: 380px;"><plasmo-csui id="jobright-helper-plugin"><template shadowrootmode="open"><style>.ant-message .ant-message-notice{padding:0}.ant-message .ant-message-notice .ant-message-notice-content{background:#7df5cd;border-radius:8px;justify-content:center;align-items:center;padding:12px;display:inline-flex;box-shadow:0 6px 24px #00d28c33}.ant-drawer .ant-drawer-content-wrapper .ant-drawer-content .ant-drawer-close{border:1px solid var(--Grey,#f2f4f5);margin:0;border-radius:8px;flex-shrink:0;justify-content:center;align-items:center;width:32px;height:32px;margin-inline-end:16px;padding:0;display:flex}.ant-drawer .ant-drawer-content-wrapper .ant-drawer-content .ant-drawer-body{padding:0}.ant-divider.ant-divider-horizontal{margin:0}.handle{background:#fff;border-radius:48px 0 0 48px;transition:transform .5s;transform:translate(24px)}.handle:hover{transform:translate(0)}.handle:hover .close-button{visibility:visible}.bird-button{cursor:pointer;padding:8px;position:relative}.close-button{cursor:pointer;visibility:hidden;background:#fff;border-radius:10px;flex-shrink:0;justify-content:center;align-items:center;padding:4px;display:flex;position:absolute;top:0;left:0;box-shadow:0 0 4px #0003}@keyframes slideIn{0%{right:-100px}to{right:0}}#jobright-helper-id.jobright-helper-content-container{z-index:1001;background:var(--base-color-secondbg,#f8f9fa);width:384px;max-height:calc(100vh - 20px);box-shadow:inset 0 0 0 .5px var(--base-color-black-10,#0000001a),0px 0px 32px 0px #000a141a;border:none;border-radius:20px;flex-direction:column;gap:8px;padding:8px;font-family:Inter,sans-serif;display:flex;position:fixed;top:10px;right:10px}#jobright-helper-id.jobright-helper-content-container .ant-typography{margin:0}#jobright-helper-id.jobright-helper-content-container .header{background:0 0;padding:0}#jobright-helper-id.jobright-helper-content-container .header .helper-header-actions{margin-left:auto}#jobright-helper-id.jobright-helper-con